# Environment Variables for Slack Channel Fetcher
# ================================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp env.example .env
# 2. Replace the token below with your actual Slack Bot Token
# 3. The .env file is gitignored - safe for local development
#
# Note: For deployment, set SLACK_TOKEN as environment variable in your platform

# Slack Bot Token (required for normal mode)
# Get from: https://api.slack.com/apps → Your App → OAuth & Permissions
SLACK_TOKEN=xoxb-your-slack-bot-token-here

# Optional: set DEMO_MODE=true to run against the baked-in sample dataset
# instead of a real Slack workspace. When set, SLACK_TOKEN is not required.
# DEMO_MODE=true

